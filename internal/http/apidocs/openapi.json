{
  "openapi": "3.0.3",
  "info": {
    "title": "Moneypath API",
    "version": "1.0.0",
    "description": "Personal finance backend API for auth, wallets, debts, mutations, dashboard, and summary."
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development"
    },
    {
      "url": "http://localhost:18080",
      "description": "Production-like local Docker deployment"
    }
  ],
  "tags": [
    { "name": "Health" },
    { "name": "Auth" },
    { "name": "Profile" },
    { "name": "Wallet" },
    { "name": "Debt" },
    { "name": "Mutation" },
    { "name": "Dashboard" },
    { "name": "Summary" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service and database are available",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          },
          "409": {
            "description": "Duplicate email or username",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login with email or username",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    },
    "/me": {
      "get": {
        "tags": ["Profile"],
        "summary": "Get current profile",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Current user profile",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Profile"],
        "summary": "Update current profile",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateProfileRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated profile",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    },
    "/me/password": {
      "put": {
        "tags": ["Profile"],
        "summary": "Change current password",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChangePasswordRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    },
    "/wallets": {
      "get": {
        "tags": ["Wallet"],
        "summary": "List active wallets",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": {
            "description": "Paginated wallets",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WalletListResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Wallet"],
        "summary": "Create wallet",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WalletRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created wallet",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WalletResponse" }
              }
            }
          }
        }
      }
    },
    "/wallets/{walletID}": {
      "get": {
        "tags": ["Wallet"],
        "summary": "Get wallet detail",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/WalletID" }
        ],
        "responses": {
          "200": {
            "description": "Wallet detail",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WalletResponse" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Wallet"],
        "summary": "Update wallet metadata",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/WalletID" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WalletRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated wallet",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WalletResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Wallet"],
        "summary": "Inactivate wallet",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/WalletID" }
        ],
        "responses": {
          "200": {
            "description": "Wallet inactivated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageResponse" }
              }
            }
          }
        }
      }
    },
    "/debts": {
      "get": {
        "tags": ["Debt"],
        "summary": "List debts",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" }
        ],
        "responses": {
          "200": {
            "description": "Paginated debts",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DebtListResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Debt"],
        "summary": "Create debt",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateDebtRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created debt",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DebtResponse" }
              }
            }
          }
        }
      }
    },
    "/debts/{debtID}": {
      "get": {
        "tags": ["Debt"],
        "summary": "Get debt detail",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/DebtID" }
        ],
        "responses": {
          "200": {
            "description": "Debt detail",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DebtResponse" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Debt"],
        "summary": "Update debt metadata",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/DebtID" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateDebtRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated debt",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DebtResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Debt"],
        "summary": "Inactivate paid debt",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/DebtID" }
        ],
        "responses": {
          "200": {
            "description": "Debt inactivated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageResponse" }
              }
            }
          }
        }
      }
    },
    "/mutations": {
      "get": {
        "tags": ["Mutation"],
        "summary": "List mutations",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/MutationType" },
          { "$ref": "#/components/parameters/WalletFilter" },
          { "$ref": "#/components/parameters/DebtFilter" },
          { "$ref": "#/components/parameters/RelatedToDebt" },
          { "$ref": "#/components/parameters/FromTimestamp" },
          { "$ref": "#/components/parameters/ToTimestamp" },
          { "$ref": "#/components/parameters/SortBy" },
          { "$ref": "#/components/parameters/SortDirection" }
        ],
        "responses": {
          "200": {
            "description": "Paginated mutations",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MutationListResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Mutation"],
        "summary": "Create mutation",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MutationRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created mutation",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MutationResponse" }
              }
            }
          }
        }
      }
    },
    "/mutations/{mutationID}": {
      "get": {
        "tags": ["Mutation"],
        "summary": "Get mutation detail",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/MutationID" }
        ],
        "responses": {
          "200": {
            "description": "Mutation detail",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MutationResponse" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Mutation"],
        "summary": "Update mutation",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/MutationID" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MutationRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated mutation",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MutationResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Mutation"],
        "summary": "Delete mutation is not allowed",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/MutationID" }
        ],
        "responses": {
          "405": {
            "description": "Delete not allowed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
              }
            }
          }
        }
      }
    },
    "/dashboard": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Get dashboard overview",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Dashboard overview",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DashboardResponse" }
              }
            }
          }
        }
      }
    },
    "/summary": {
      "get": {
        "tags": ["Summary"],
        "summary": "Get summary report",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "query",
            "name": "from",
            "schema": { "type": "string", "format": "date" },
            "description": "Start date in YYYY-MM-DD"
          },
          {
            "in": "query",
            "name": "to",
            "schema": { "type": "string", "format": "date" },
            "description": "End date in YYYY-MM-DD"
          }
        ],
        "responses": {
          "200": {
            "description": "Summary report",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SummaryResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "Page": {
        "in": "query",
        "name": "page",
        "schema": { "type": "integer", "default": 1, "minimum": 1 }
      },
      "PageSize": {
        "in": "query",
        "name": "page_size",
        "schema": { "type": "integer", "default": 20, "minimum": 1, "maximum": 100 }
      },
      "WalletID": {
        "in": "path",
        "name": "walletID",
        "required": true,
        "schema": { "type": "string" }
      },
      "DebtID": {
        "in": "path",
        "name": "debtID",
        "required": true,
        "schema": { "type": "string" }
      },
      "MutationID": {
        "in": "path",
        "name": "mutationID",
        "required": true,
        "schema": { "type": "string" }
      },
      "MutationType": {
        "in": "query",
        "name": "type",
        "schema": { "type": "string", "enum": ["masuk", "keluar"] }
      },
      "WalletFilter": {
        "in": "query",
        "name": "wallet_id",
        "schema": { "type": "string" }
      },
      "DebtFilter": {
        "in": "query",
        "name": "debt_id",
        "schema": { "type": "string" }
      },
      "RelatedToDebt": {
        "in": "query",
        "name": "related_to_debt",
        "schema": { "type": "boolean" }
      },
      "FromTimestamp": {
        "in": "query",
        "name": "from",
        "schema": { "type": "string", "format": "date-time" }
      },
      "ToTimestamp": {
        "in": "query",
        "name": "to",
        "schema": { "type": "string", "format": "date-time" }
      },
      "SortBy": {
        "in": "query",
        "name": "sort_by",
        "schema": { "type": "string", "enum": ["happened_at", "created_at", "amount"] }
      },
      "SortDirection": {
        "in": "query",
        "name": "sort_direction",
        "schema": { "type": "string", "enum": ["asc", "desc"] }
      }
    },
    "schemas": {
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "page": { "type": "integer" },
          "page_size": { "type": "integer" },
          "total_items": { "type": "integer" },
          "total_pages": { "type": "integer" }
        }
      },
      "APIError": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "ErrorEnvelope": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": { "$ref": "#/components/schemas/APIError" }
        }
      },
      "MessageData": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/MessageData" }
        }
      },
      "HealthData": {
        "type": "object",
        "properties": {
          "service": { "type": "string" },
          "database": { "type": "string" }
        }
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/HealthData" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "username": { "type": "string" },
          "full_name": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/User" }
        }
      },
      "AuthData": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "user": { "$ref": "#/components/schemas/User" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/AuthData" }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["email", "username", "password", "full_name"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "username": { "type": "string" },
          "password": { "type": "string" },
          "full_name": { "type": "string" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email_or_username", "password"],
        "properties": {
          "email_or_username": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "UpdateProfileRequest": {
        "type": "object",
        "required": ["email", "username", "full_name"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "username": { "type": "string" },
          "full_name": { "type": "string" }
        }
      },
      "ChangePasswordRequest": {
        "type": "object",
        "required": ["current_password", "new_password"],
        "properties": {
          "current_password": { "type": "string" },
          "new_password": { "type": "string" }
        }
      },
      "Wallet": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "user_id": { "type": "string" },
          "name": { "type": "string" },
          "balance": { "type": "string" },
          "is_active": { "type": "boolean" },
          "deleted_at": { "type": "string", "format": "date-time", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "WalletRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" }
        }
      },
      "WalletResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/Wallet" }
        }
      },
      "WalletListResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Wallet" }
          },
          "meta": { "$ref": "#/components/schemas/PaginationMeta" }
        }
      },
      "Debt": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "user_id": { "type": "string" },
          "name": { "type": "string" },
          "principal_amount": { "type": "string" },
          "remaining_amount": { "type": "string" },
          "tenor_value": { "type": "integer", "nullable": true },
          "tenor_unit": { "type": "string", "nullable": true },
          "payment_amount": { "type": "string", "nullable": true },
          "status": { "type": "string" },
          "is_active": { "type": "boolean" },
          "note": { "type": "string", "nullable": true },
          "deleted_at": { "type": "string", "format": "date-time", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateDebtRequest": {
        "type": "object",
        "required": ["name", "principal_amount"],
        "properties": {
          "name": { "type": "string" },
          "principal_amount": { "type": "string" },
          "tenor_value": { "type": "integer", "nullable": true },
          "tenor_unit": { "type": "string", "nullable": true },
          "payment_amount": { "type": "string", "nullable": true },
          "note": { "type": "string", "nullable": true }
        }
      },
      "UpdateDebtRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "tenor_value": { "type": "integer", "nullable": true },
          "tenor_unit": { "type": "string", "nullable": true },
          "payment_amount": { "type": "string", "nullable": true },
          "note": { "type": "string", "nullable": true }
        }
      },
      "DebtResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "$ref": "#/components/schemas/Debt" }
        }
      },
      "DebtListResponse": {
        "type": "object",
        "properties": {
